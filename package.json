{
  "name": "voxlibro-ai-codex",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap=external --outfile=server-dist/server.cjs",
    "start": "NODE_ENV=production node server-dist/server.cjs",
    "clean": "rm -rf dist server-dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "verify:c00": "npm run test:run && npm run lint && npm run build",
    "verify:c01": "npm run test:run && npm run lint && npm run build",
    "verify:c03": "npm run test:run && npm run lint && npm run build",
    "verify:c04": "npm run test:run && npm run lint && npm run build",
    "verify:c05": "npm run test:run && npm run lint && npm run build",
    "verify:c06": "npm run test:run && npm run lint && npm run build",
    "verify:c07": "npm run test:run && npm run lint && npm run build",
    "verify:c10": "vitest run c10-verify.test.ts",
    "verify:c11": "vitest run c11-verify.test.ts",
    "verify:c12": "vitest run c12-verify.test.ts",
    "verify:c13": "vitest run c13-verify.test.ts",
    "verify:all": "npm run lint && npm run build && npm run test:run"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "adm-zip": "^0.6.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "google-auth-library": "^10.9.0",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10"
  }
}
